---
import BaseLayout from './BaseLayout.astro';
import EvidenceCard from '../components/EvidenceCard.astro';
import { url } from '../utils/base';

interface Props {
  title: string;
  phase: 'discover' | 'define' | 'design' | 'refine' | 'deliver';
  description: string;
  phaseNumber: string;
  evidence?: Array<{
    title: string;
    description: string;
    href: string;
    icon: string;
  }>;
}

const { title, phase, description, phaseNumber, evidence = [] } = Astro.props;

const phaseConfig: Record<string, { bg: string; color: string; gradient: string; number: string }> = {
  discover: { bg: 'bg-phase-discover', color: 'text-phase-discover', gradient: 'from-phase-discover to-phase-discover/60', number: '01' },
  define: { bg: 'bg-phase-define', color: 'text-phase-define', gradient: 'from-phase-define to-phase-define/60', number: '02' },
  design: { bg: 'bg-phase-design', color: 'text-phase-design', gradient: 'from-phase-design to-phase-design/60', number: '03' },
  refine: { bg: 'bg-phase-refine', color: 'text-phase-refine', gradient: 'from-phase-refine to-phase-refine/60', number: '04' },
  deliver: { bg: 'bg-phase-deliver', color: 'text-phase-deliver', gradient: 'from-phase-deliver to-phase-deliver/60', number: '05' },
};

const config = phaseConfig[phase];
---

<BaseLayout title={title}>
  <!-- Phase Hero -->
  <section class="bg-dark text-white overflow-hidden relative">
    <div class={`absolute top-0 right-0 w-96 h-96 ${config.bg}/20 rounded-full blur-3xl`}></div>

    <div class="max-w-6xl mx-auto px-6 py-16 md:py-24 relative z-10">
      <div class="reveal flex items-center gap-4 mb-4">
        <span class={`${config.bg} text-white text-sm font-bold px-4 py-1.5 rounded-full`}>
          {phaseNumber}
        </span>
        <a href={url('/')} class="text-white/40 hover:text-white/60 text-sm transition-colors">
          &larr; Terug naar home
        </a>
      </div>
      <h1 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-bold leading-[0.95] mb-4">
        {title}
      </h1>
      <p class="reveal reveal-delay-2 text-xl text-white/60 max-w-3xl leading-relaxed">{description}</p>

      <div class={`reveal reveal-delay-3 w-24 h-1.5 rounded-full ${config.bg} mt-8`}></div>
    </div>
  </section>

  <!-- Content -->
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="reveal prose max-w-none mb-16">
      <slot />
    </div>

    {evidence.length > 0 && (
      <section class="reveal">
        <h2 class="font-[family-name:var(--font-display)] text-3xl font-bold text-dark mb-8">Bewijsstukken</h2>
        <div class="grid gap-4 md:grid-cols-2">
          {evidence.map((item, i) => (
            <div class={`reveal reveal-delay-${i + 1}`}>
              <EvidenceCard
                title={item.title}
                description={item.description}
                href={item.href}
                phase={phase}
                icon={item.icon}
              />
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
