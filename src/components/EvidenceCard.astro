---
interface Props {
  title: string;
  description: string;
  href: string;
  phase: string;
  icon?: string;
}

const { title, description, href, phase, icon = '' } = Astro.props;

const phaseColors: Record<string, { bg: string; text: string; border: string }> = {
  discover: { bg: 'bg-phase-discover', text: 'text-phase-discover', border: 'border-phase-discover' },
  define: { bg: 'bg-phase-define', text: 'text-phase-define', border: 'border-phase-define' },
  design: { bg: 'bg-phase-design', text: 'text-phase-design', border: 'border-phase-design' },
  refine: { bg: 'bg-phase-refine', text: 'text-phase-refine', border: 'border-phase-refine' },
  deliver: { bg: 'bg-phase-deliver', text: 'text-phase-deliver', border: 'border-phase-deliver' },
};

const colors = phaseColors[phase] || phaseColors.discover;
---

<a
  href={href}
  class="block bg-bg-elevated rounded-2xl border-2 border-transparent hover:border-current p-5 hover:shadow-lg transition-all duration-300 group hover-wobble"
  style={`--tw-border-opacity: 0.3;`}
>
  <div class="flex items-start gap-4">
    <div class={`w-12 h-12 rounded-xl ${colors.bg} flex items-center justify-center text-white text-xl flex-shrink-0 group-hover:scale-110 transition-transform`}>
      {icon}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-lg group-hover:text-dark-light transition-colors">{title}</h3>
      <p class="text-sm text-dark/50 mt-1 leading-relaxed">{description}</p>
    </div>
    <svg class={`w-5 h-5 ${colors.text} flex-shrink-0 mt-1 group-hover:translate-x-1 transition-all opacity-0 group-hover:opacity-100`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M9 18l6-6-6-6" />
    </svg>
  </div>
</a>
