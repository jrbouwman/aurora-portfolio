---
import { url } from '../utils/base';

const phases = [
  { name: 'Discover', href: url('/discover/'), color: 'bg-phase-discover' },
  { name: 'Define', href: url('/define/'), color: 'bg-phase-define' },
  { name: 'Design', href: url('/design/'), color: 'bg-phase-design' },
  { name: 'Refine', href: url('/refine/'), color: 'bg-phase-refine' },
  { name: 'Deliver', href: url('/deliver/'), color: 'bg-phase-deliver' },
];

const currentPath = Astro.url.pathname;
---

<nav class="bg-dark text-white sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={url('/')} class="flex items-center gap-3 group">
        <svg viewBox="0 0 32 32" class="w-9 h-9 group-hover:scale-110 transition-transform" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="aurora-nav" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#2D7AFF"/>
              <stop offset="50%" stop-color="#8B2DFF"/>
              <stop offset="100%" stop-color="#FF2D78"/>
            </linearGradient>
          </defs>
          <rect width="32" height="32" rx="7" fill="#1A1A2E"/>
          <g transform="translate(16,16) rotate(-20) translate(-16,-16)">
            <rect x="13" y="4" width="6" height="16" rx="2" fill="url(#aurora-nav)"/>
            <path d="M13,20 L16,28 L19,20 Z" fill="url(#aurora-nav)"/>
            <rect x="19.5" y="5" width="1.5" height="9" rx="0.75" fill="white" opacity="0.35"/>
            <circle cx="16" cy="27" r="1" fill="white" opacity="0.7"/>
          </g>
        </svg>
        <span class="font-[family-name:var(--font-display)] font-bold text-lg hidden sm:block">Aurora</span>
      </a>

      <!-- Phase Tabs -->
      <div class="flex items-center gap-1">
        {phases.map((phase) => {
          const isActive = currentPath.startsWith(phase.href);
          return (
            <a
              href={phase.href}
              class:list={[
                'px-3 py-2 rounded-xl text-sm font-medium transition-all duration-200',
                isActive
                  ? 'bg-white/15 text-white'
                  : 'text-white/50 hover:text-white hover:bg-white/10',
              ]}
            >
              <span class:list={['inline-block w-2.5 h-2.5 rounded-full mr-1.5 transition-transform', phase.color, isActive && 'scale-125']} />
              <span class="hidden md:inline">{phase.name}</span>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</nav>
