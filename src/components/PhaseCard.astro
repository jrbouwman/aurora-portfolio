---
interface Props {
  title: string;
  description: string;
  href: string;
  phase: string;
  label: string;
  evidenceCount?: number;
}

const { title, description, href, phase, label, evidenceCount = 0 } = Astro.props;

const phaseColors: Record<string, { bg: string; text: string; border: string }> = {
  discover: { bg: 'bg-phase-discover', text: 'text-phase-discover', border: 'border-phase-discover' },
  define: { bg: 'bg-phase-define', text: 'text-phase-define', border: 'border-phase-define' },
  design: { bg: 'bg-phase-design', text: 'text-phase-design', border: 'border-phase-design' },
  refine: { bg: 'bg-phase-refine', text: 'text-phase-refine', border: 'border-phase-refine' },
  deliver: { bg: 'bg-phase-deliver', text: 'text-phase-deliver', border: 'border-phase-deliver' },
};

const colors = phaseColors[phase] || phaseColors.discover;
---

<a
  href={href}
  class={`block bg-bg-elevated rounded-2xl border-2 border-transparent ${colors.border} p-6 hover:shadow-xl hover:-translate-y-1 hover:scale-[1.02] transition-all duration-300 group`}
>
  <div class="flex items-start justify-between mb-3">
    <span class={`text-xs font-bold ${colors.bg} text-white px-2.5 py-1 rounded-full`}>{label}</span>
    {evidenceCount > 0 && (
      <span class="text-xs font-bold text-dark/40 bg-bg-secondary px-2.5 py-1 rounded-full">
        {evidenceCount} items
      </span>
    )}
  </div>
  <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark mb-2 group-hover:text-dark-light transition-colors">{title}</h3>
  <p class="text-dark/50 text-sm leading-relaxed">{description}</p>
  <div class={`mt-4 flex items-center text-sm font-bold ${colors.text} group-hover:gap-2 transition-all`}>
    <span>Bekijk fase</span>
    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </div>
</a>
