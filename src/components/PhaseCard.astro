---
interface Props {
  title: string;
  description: string;
  href: string;
  phase: string;
  label: string;
  evidenceCount?: number;
}

const { title, description, href, phase, label, evidenceCount = 0 } = Astro.props;

const phaseColors: Record<string, { border: string; bg: string; dot: string }> = {
  discover: { border: 'border-l-phase-discover', bg: 'bg-phase-discover/5', dot: 'bg-phase-discover' },
  define: { border: 'border-l-phase-define', bg: 'bg-phase-define/5', dot: 'bg-phase-define' },
  design: { border: 'border-l-phase-design', bg: 'bg-phase-design/5', dot: 'bg-phase-design' },
  refine: { border: 'border-l-phase-refine', bg: 'bg-phase-refine/5', dot: 'bg-phase-refine' },
  deliver: { border: 'border-l-phase-deliver', bg: 'bg-phase-deliver/5', dot: 'bg-phase-deliver' },
};

const colors = phaseColors[phase] || phaseColors.discover;
---

<a
  href={href}
  class={`block bg-white rounded-xl shadow-md border-l-4 ${colors.border} p-6 hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5 group`}
>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2">
      <div class={`w-2.5 h-2.5 rounded-full ${colors.dot}`} />
      <span class="text-xs font-semibold text-navy/50 uppercase tracking-wide">{label}</span>
    </div>
    {evidenceCount > 0 && (
      <span class={`text-xs font-medium ${colors.bg} px-2 py-0.5 rounded-full text-navy/70`}>
        {evidenceCount} bewijsstukken
      </span>
    )}
  </div>
  <h3 class="text-xl font-bold text-navy mb-2 group-hover:text-navy-light transition-colors">{title}</h3>
  <p class="text-navy/60 text-sm leading-relaxed">{description}</p>
  <div class="mt-4 flex items-center text-sm font-medium text-navy/40 group-hover:text-navy/60 transition-colors">
    <span>Bekijk fase</span>
    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </div>
</a>
