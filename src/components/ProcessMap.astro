---
import { url } from '../utils/base';

const phases = [
  { name: 'Discover', href: url('/discover/'), color: 'bg-phase-discover', label: 'BK 1-2' },
  { name: 'Define', href: url('/define/'), color: 'bg-phase-define', label: 'BK 3' },
  { name: 'Design', href: url('/design/'), color: 'bg-phase-design', label: 'BK 4' },
  { name: 'Refine', href: url('/refine/'), color: 'bg-phase-refine', label: 'BK 5-6' },
  { name: 'Deliver', href: url('/deliver/'), color: 'bg-phase-deliver', label: 'BK 7-9' },
];
---

<div class="w-full overflow-x-auto pb-4">
  <div class="flex items-center justify-center gap-3 min-w-[600px] px-4">
    {phases.map((phase, i) => (
      <>
        <a href={phase.href} class="group flex flex-col items-center">
          <div class={`w-28 h-16 ${phase.color} rounded-2xl flex flex-col items-center justify-center transition-all duration-300 group-hover:scale-110 group-hover:-translate-y-1 shadow-lg`}>
            <span class="text-white font-bold text-sm">{phase.name}</span>
          </div>
          <span class="text-xs text-dark/40 mt-2 font-medium">{phase.label}</span>
        </a>

        {i < phases.length - 1 && (
          <div class="flex items-center gap-1 text-white/10">
            <div class="w-2 h-2 rounded-full bg-accent-yellow"></div>
            <div class="w-6 h-0.5 bg-white/5"></div>
            <div class="w-2 h-2 rotate-45 bg-accent-yellow rounded-sm flex items-center justify-center">
              <span class="text-[6px] font-bold text-text-secondary -rotate-45">G</span>
            </div>
            <div class="w-6 h-0.5 bg-white/5"></div>
          </div>
        )}
      </>
    ))}
  </div>
</div>
