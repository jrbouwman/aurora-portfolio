---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/base';

const challenges = [
  {
    num: 1,
    color: 'border-l-phase-discover',
    bg: 'bg-phase-discover',
    title: 'Hoe zouden we een pen kunnen laten meedenken, zoals digitale tools dat doen?',
    basis: 'Dreams: meedenkende pen, AI synoniemen, lijntjes strakmaken',
    thema: 'Slim & digitaal',
  },
  {
    num: 2,
    color: 'border-l-phase-define',
    bg: 'bg-phase-define',
    title: 'Hoe zouden we schrijfgerei persoonlijker en aanpasbaar kunnen maken?',
    basis: 'Dreams: persoonlijker, handschriftstijl, veel kleuren, modulair',
    thema: 'Persoonlijk & multifunctioneel',
  },
  {
    num: 3,
    color: 'border-l-phase-design',
    bg: 'bg-phase-design',
    title: 'Hoe zouden we schrijven comfortabeler kunnen maken, ook voor linkshandigen?',
    basis: 'Gripes: vermoeidheid, linkshandigen, geluid + Dreams: ergonomie, friemelen',
    thema: 'Comfort & inclusiviteit',
  },
  {
    num: 4,
    color: 'border-l-phase-refine',
    bg: 'bg-phase-refine',
    title: 'Hoe zouden we kunnen voorkomen dat pennen uitdrogen, lekken of kapotgaan?',
    basis: 'Gripes: inkt droogt uit, pen lekt, lipje breekt af, dop kwijt',
    thema: 'Betrouwbaarheid & duurzaamheid',
  },
  {
    num: 5,
    color: 'border-l-phase-deliver',
    bg: 'bg-phase-deliver',
    title: 'Hoe zouden we een pen kunnen beveiligen zodat je handtekening niet te vervalsen is?',
    basis: 'Dream: beveiligde pen met vingerafdrukherkenning',
    thema: 'Beveiliging & authenticiteit',
  },
];
---

<BaseLayout title="Challenges — Discover">
  <!-- Hero with image -->
  <section class="bg-bg-primary text-white overflow-hidden relative">
    <div class="absolute inset-0">
      <img src={url('/images/research/challenges-hero.jpeg')} alt="" class="w-full h-full object-cover opacity-20" />
      <div class="absolute inset-0 bg-gradient-to-b from-bg-primary/60 to-bg-primary"></div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 md:py-24 relative z-10">
      <nav class="reveal text-sm mb-6 flex items-center gap-2">
        <a href={url('/')} class="text-white/40 hover:text-white/60 transition-colors">Home</a>
        <span class="text-white/20">/</span>
        <a href={url('/discover/')} class="text-white/40 hover:text-white/60 transition-colors">Discover</a>
        <span class="text-white/20">/</span>
        <span class="text-phase-discover font-medium">Challenges</span>
      </nav>
      <h1 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-bold leading-[0.95] mb-4">
        Innovatie<span class="gradient-text">challenges</span>
      </h1>
      <p class="reveal reveal-delay-2 text-xl text-white/60 max-w-3xl leading-relaxed">
        De dreams en gripes uit ons onderzoek omgezet naar concrete "Hoe Zouden We Kunnen...?" vragen.
      </p>
      <div class="reveal reveal-delay-3 w-24 h-1.5 rounded-full bg-phase-discover mt-8"></div>
    </div>
  </section>

  <!-- HZWK uitleg -->
  <section class="bg-cream py-16">
    <div class="max-w-4xl mx-auto px-6">
      <div class="reveal bg-bg-elevated rounded-3xl p-8 md:p-10 shadow-sm border border-white/5">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-accent-yellow rounded-2xl flex items-center justify-center text-dark text-xl flex-shrink-0 font-bold">?</div>
          <div>
            <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold text-dark mb-3">De HZWK-methode</h2>
            <p class="text-dark/60 leading-relaxed mb-3">
              <strong class="text-dark">Hoe Zouden We Kunnen...?</strong> (How Might We?) zet inzichten uit immersive research om in acteerbare innovatie-uitdagingen.
              Breed genoeg voor creatieve oplossingen, specifiek genoeg om richting te geven.
            </p>
            <p class="text-dark/40 text-sm">
              Treffinger (1995), Creative Problem Solving &middot; <a href={url('/discover/empathise/')} class="underline hover:text-dark/60">Immersive research</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HZWK Challenges -->
  <section class="bg-warm-gray py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">HZWK Challenges</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-10">5 eerste challenges afgeleid uit de dreams & gripes van de discover-fase</p>

      <div class="reveal reveal-delay-2 space-y-4">
        {challenges.map((c) => (
          <div class={`bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm border-l-4 ${c.color}`}>
            <div class="flex items-start gap-4">
              <div class={`w-10 h-10 ${c.bg} rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0`}>
                {c.num}
              </div>
              <div class="flex-1">
                <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-lg mb-2 leading-snug">
                  {c.title}
                </h3>
                <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs text-dark/50 mt-2">
                  <span><strong class="text-dark/70">Basis:</strong> {c.basis}</span>
                  <span><strong class="text-dark/70">Thema:</strong> {c.thema}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="bg-cream py-16">
    <div class="max-w-4xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <a href={url('/discover/empathise/')} class="reveal inline-flex items-center gap-2 text-dark/50 hover:text-dark font-bold transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
        Immersive Research
      </a>
      <div class="reveal reveal-delay-1 text-center">
        <p class="text-dark/40 text-sm mb-3">Discover afgerond, door naar Define</p>
        <a href={url('/define/')} class="inline-flex items-center gap-2 bg-phase-define text-white font-bold px-6 py-3 rounded-full hover:scale-105 transition-transform">
          Naar Define (Fase 2)
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
