  <script>
    // Porter overlay logic
    document.querySelectorAll('.porter-card').forEach(card => {
      card.addEventListener('click', () => {
        const id = card.getAttribute('data-porter');
        const overlay = document.getElementById(`porter-overlay-${id}`);
        if (overlay) {
          overlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      });
    });
    document.querySelectorAll('.porter-overlay').forEach(overlay => {
      overlay.querySelectorAll('[data-close]').forEach(btn => {
        btn.addEventListener('click', () => {
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        });
      });
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.porter-overlay').forEach(o => o.classList.add('hidden'));
        document.body.style.overflow = '';
      }
    });
  </script>

