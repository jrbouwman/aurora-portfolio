---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/base';

// Dreams geclusterd per thema (uit sessie 1 + 2)
const dreamClusters = [
  {
    thema: 'Slim & digitaal',
    items: ['Meedenkende pen (AI denkt mee met synoniemen, spelling)', 'Lijntjes automatisch strakmaken zoals digitale tools'],
  },
  {
    thema: 'Comfort & ergonomie',
    items: ['Zwaardere pen voor prettiger schrijfgevoel', 'Glad oppervlak zonder storende textuur', 'Friemelen voor rust/ontspanning zonder verstoring'],
  },
  {
    thema: 'Multifunctioneel',
    items: ['Veel kleuren in één dunne pen', 'Schrijven en markeren in één', 'Modulaire pen (demonteren & samenstellen)'],
  },
  {
    thema: 'Persoonlijk & expressie',
    items: ['Handschriftstijl als persoonlijk kenmerk', 'Persoonlijker overkomen dan met computer'],
  },
  {
    thema: 'Beveiliging',
    items: ['Vingerafdrukherkenning voor handtekeningen'],
  },
  {
    thema: 'Welzijn',
    items: ['Schrijven vermindert stress', 'Goed voor motoriek en hand-oogcoördinatie'],
  },
];

// Gripes geclusterd per thema (uit sessie 1 + 2)
const gripeClusters = [
  {
    thema: 'Slijtage & uitdroging',
    items: ['Inkt droogt uit of veegt weg', 'Stiften drogen uit zonder dop', 'Pen lekt bij leegraken', 'Schrijfgerei raakt onverwacht op'],
  },
  {
    thema: 'Fysiek ongemak',
    items: ['Vermoeidheid bij lang schrijven', 'Linkshandigen: hand door inkt', 'Storend klikgeluid', 'Dikke pen is hinderlijk'],
  },
  {
    thema: 'Kwaliteit & duurzaamheid',
    items: ['Lipje/clipje breekt af', 'Dop kwijtraken', 'Pennen raak je kwijt, niet duurzaam door massaproductie'],
  },
  {
    thema: 'Functionaliteit',
    items: ['Moeilijk corrigeren op papier', 'Onleesbaar handschrift', 'Afhankelijk van papier en hulpmiddelen', 'Gelimiteerde kleuropties'],
  },
];

// Ruwe observaties uit sessie 1 die niet direct als dream/gripe gelabeld waren
const observaties = [
  'Prikkelend: verschillende zintuigen (tast, visueel, bewegen)',
  'Gevoel en geur van schrijven',
  'Meer nadenken bij wat je doet tijdens schrijven',
  'Sneller voor kleine/korte handelingen',
  'Makkelijker meenemen dan digitale apparaten',
  'Geen accu of stopcontact nodig (voordeel analoog)',
  'Computer/digitaal kan verslavend zijn',
  'Gelimiteerd bij toetsen op computer (formulierbladen enz.)',
  'Computer: ook andere dingen mee doen (afleiden tijdens les)',
  'Langer dan typen over langere tijd (kost meer tijd)',
  'Gebruiksvriendelijkheid (algemeen)',
];
---

<BaseLayout title="Immersive Research — Discover">
  <!-- Hero with image -->
  <section class="bg-bg-primary text-white overflow-hidden relative">
    <div class="absolute inset-0">
      <img src={url('/images/research/dreams-gripes.jpeg')} alt="" class="w-full h-full object-cover opacity-15" />
      <div class="absolute inset-0 bg-gradient-to-b from-bg-primary/60 to-bg-primary"></div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 md:py-24 relative z-10">
      <nav class="reveal text-sm mb-6 flex items-center gap-2">
        <a href={url('/')} class="text-white/40 hover:text-white/60 transition-colors">Home</a>
        <span class="text-white/20">/</span>
        <a href={url('/discover/')} class="text-white/40 hover:text-white/60 transition-colors">Discover</a>
        <span class="text-white/20">/</span>
        <span class="text-phase-discover font-medium">Immersive Research</span>
      </nav>
      <h1 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-bold leading-[0.95] mb-4">
        Immersive<br /><span class="gradient-text">Research</span>
      </h1>
      <p class="reveal reveal-delay-2 text-xl text-white/60 max-w-3xl leading-relaxed">
        Hoe ervaren mensen het schrijven met pen en papier eigenlijk? We zijn het gaan uitzoeken.
      </p>
      <div class="reveal reveal-delay-3 w-24 h-1.5 rounded-full bg-phase-discover mt-8"></div>
    </div>
  </section>

  <!-- Inleiding -->
  <section class="bg-cream py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-8 text-center">Onderzoeksaanpak</h2>

      <div class="reveal reveal-delay-1 prose max-w-none mb-10">
        <p>We hebben twee sessies gedaan: eerst onze eigen ervaringen met schrijfgerei besproken (<strong>learn from experience</strong>), daarna andere mensen geïnterviewd (<strong>learn from users</strong>). Het idee was om niet meteen in oplossingen te denken, maar gewoon te kijken wat er leeft.</p>
      </div>

      <div class="reveal reveal-delay-2 grid md:grid-cols-2 gap-6">
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-discover rounded-xl flex items-center justify-center text-white text-lg">1</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Learn from Experience</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            We hebben nagedacht over onze eigen ervaringen met pennen, potloden en schrijven op de computer. Wat vinden we fijn, wat niet? Per punt hebben we aangegeven of het een <strong class="text-phase-deliver">dream</strong>, <strong class="text-phase-discover">gripe</strong> of gewoon een observatie was.
          </p>
        </div>
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-define rounded-xl flex items-center justify-center text-white text-lg">2</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Learn from Users</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            We hebben twee mensen (Anna en Famke) gevraagd naar hun ervaringen met pennen. Wat vinden zij er fijn aan, wat irriteert ze?
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sessie 1: Learn from Experience -->
  <section class="bg-warm-gray py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">Sessie 1 — Learn from Experience</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-10">Brainstormen over eigen ervaringen met schrijfgerei</p>

      <div class="reveal reveal-delay-2 prose max-w-none mb-10">
        <p>We zijn gestart met een brainstormsessie over onze eigen ervaringen met schrijfgerei en het schrijfgebruik op de computer. We hebben alles opgeschreven, en waar het kon aangegeven of het een <strong class="text-phase-deliver">dream</strong> of <strong class="text-phase-discover">gripe</strong> was. Sommige punten waren meer een algemene observatie.</p>
      </div>

      <!-- Media grid -->
      <div class="reveal reveal-delay-2 grid md:grid-cols-2 gap-6 mb-10">
        <div>
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
            <video autoplay loop muted playsinline class="w-full">
              <source src={url('/images/research/sessie1-timelapse.mp4')} type="video/mp4" />
            </video>
          </div>
          <p class="text-dark/40 text-sm text-center mt-3 italic">Timelapse van de brainstormsessie</p>
        </div>
        <div>
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
            <img src={url('/images/research/sessie1-foto.jpeg')} alt="Sessie 1 — brainstorm resultaten op whiteboard" class="w-full h-full object-cover" />
          </div>
          <p class="text-dark/40 text-sm text-center mt-3 italic">Resultaten op het whiteboard</p>
        </div>
      </div>

      <!-- Observaties (niet gelabeld als dream/gripe) -->
      <div class="reveal bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
        <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-sm mb-3 uppercase tracking-wide">Observaties analoog vs. digitaal</h3>
        <div class="grid md:grid-cols-2 gap-x-6 gap-y-1.5">
          {observaties.map((item) => (
            <p class="text-dark/60 text-sm flex items-start gap-2">
              <span class="text-dark/30 mt-0.5 text-xs flex-shrink-0">&bull;</span>
              {item}
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Sessie 2: Learn from Users -->
  <section class="bg-cream py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">Sessie 2 — Learn from Users</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-10">Interviews en gesprekken met gebruikers</p>

      <div class="reveal reveal-delay-2 prose max-w-none mb-10">
        <p>In de tweede sessie hebben we innovatie-ideeën op papier gezet en geclusterd in thema's. Daarnaast hebben we andere mensen gevraagd naar hun ervaringen met schrijfgerei.</p>
      </div>

      <div class="reveal reveal-delay-2 grid md:grid-cols-2 gap-6">
        <!-- Interview Anna -->
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-define rounded-xl flex items-center justify-center text-white text-sm font-bold">A</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-lg">Interview Anna</h3>
          </div>
          <ul class="text-text-secondary text-sm space-y-2 list-none pl-0">
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Friemelen aan pen is fijn</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Zwaardere pen zou chill zijn</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Veel kleuropties, niet te dikke pen</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Kunnen friemelen zonder dat het de rest beïnvloedt</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">&minus;</span> Geluid: te luid klikgeluid</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">&minus;</span> Vieze handen door inkt</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">&minus;</span> Kapot clipje is frustrerend</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">&minus;</span> Pen die leeg raakt</li>
          </ul>
        </div>

        <!-- Interview Famke -->
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-design rounded-xl flex items-center justify-center text-white text-sm font-bold">F</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-lg">Interview Famke</h3>
          </div>
          <ul class="text-text-secondary text-sm space-y-2 list-none pl-0">
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Ergonomisch gevormde grip is chill</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Pen demonteren en in elkaar zetten</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Schrijven en markeren in één pen</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Balpen schrijft het fijnst</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">&minus;</span> Dikke pen is hinderlijk</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">&minus;</span> Geen textuur / te glad is vervelend</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">&minus;</span> Niet te veel kleine onderdelen</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Dreams & Gripes geclusterd -->
  <section class="bg-warm-gray py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">Dreams & Gripes</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-10">Geclusterd uit sessie 1 en 2</p>

      <div class="reveal reveal-delay-2 grid md:grid-cols-2 gap-10">
        <!-- Dreams -->
        <div>
          <div class="flex items-center gap-2 mb-5">
            <div class="w-8 h-8 bg-phase-deliver rounded-lg flex items-center justify-center text-white text-sm">&#10024;</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Dreams</h3>
            <span class="text-dark/30 text-sm ml-auto">{dreamClusters.length} clusters</span>
          </div>
          <div class="space-y-4">
            {dreamClusters.map((cluster) => (
              <div class="bg-phase-deliver/5 border border-phase-deliver/15 rounded-xl p-4">
                <h4 class="font-[family-name:var(--font-display)] font-bold text-dark text-sm mb-2">{cluster.thema}</h4>
                <ul class="space-y-1">
                  {cluster.items.map((item) => (
                    <li class="text-dark/60 text-xs flex items-start gap-1.5">
                      <span class="text-phase-deliver/50 mt-0.5">&bull;</span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <!-- Gripes -->
        <div>
          <div class="flex items-center gap-2 mb-5">
            <div class="w-8 h-8 bg-phase-discover rounded-lg flex items-center justify-center text-white text-sm">&#9889;</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Gripes</h3>
            <span class="text-dark/30 text-sm ml-auto">{gripeClusters.length} clusters</span>
          </div>
          <div class="space-y-4">
            {gripeClusters.map((cluster) => (
              <div class="bg-phase-discover/5 border border-phase-discover/15 rounded-xl p-4">
                <h4 class="font-[family-name:var(--font-display)] font-bold text-dark text-sm mb-2">{cluster.thema}</h4>
                <ul class="space-y-1">
                  {cluster.items.map((item) => (
                    <li class="text-dark/60 text-xs flex items-start gap-1.5">
                      <span class="text-phase-discover/50 mt-0.5">&bull;</span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="bg-bg-primary text-white py-16">
    <div class="max-w-4xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <a href={url('/discover/scenario/')} class="reveal inline-flex items-center gap-2 text-white/50 hover:text-white font-bold transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
        Scenariobouwing
      </a>
      <a href={url('/discover/challenges/')} class="reveal reveal-delay-1 inline-flex items-center gap-2 bg-phase-discover text-white font-bold px-6 py-3 rounded-full hover:scale-105 transition-transform">
        Challenges
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </a>
    </div>
  </section>
</BaseLayout>
