---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../utils/base';

const dreams = [
  { title: 'Meedenkende pen', hzwk: 'Hoe zouden we kunnen zorgen dat een pen actief meedenkt, net zoals digitale tools dat doen, bijvoorbeeld door lijnen automatisch recht te maken en spelling te controleren?' },
  { title: 'Gebruiksvriendelijker schrijfgerei', hzwk: 'Hoe zouden we het schrijfgerei gebruiksvriendelijker kunnen maken?' },
  { title: 'Persoonlijker schrijfgerei', hzwk: 'Hoe zouden we schrijfgerei persoonlijker kunnen maken voor de gebruiker?' },
  { title: 'Veel kleuren, dunne pen', hzwk: 'Hoe zouden we meerdere kleuropties in één schrijfgerei kunnen aanbieden, zonder dat de pen te dik wordt om prettig vast te houden?' },
  { title: 'Lipje breekt niet af', hzwk: 'Hoe zouden we kunnen voorkomen dat het lipje van een pen of marker afbreekt?' },
  { title: 'Inkt droogt niet uit', hzwk: 'Hoe zouden we ervoor kunnen zorgen dat de inkt niet uitdroogt en niet uitveegt?' },
  { title: 'Stiften drogen niet uit', hzwk: 'Hoe zouden we kunnen voorkomen dat markeerstiften uitdrogen, ook wanneer de dop er per ongeluk niet op wordt gedaan?' },
  { title: 'Zwaardere pen', hzwk: 'Hoe zouden we een pen zo kunnen ontwerpen dat het gewicht prettiger aanvoelt tijdens het schrijven?' },
  { title: 'Glad oppervlak', hzwk: 'Hoe zouden we het oppervlak van schrijfgerei prettiger kunnen maken, bijvoorbeeld gladder en zonder storende textuur?' },
  { title: 'Modulaire pen', hzwk: 'Hoe zouden we een pen modulair of demonteerbaar kunnen ontwerpen, zodat gebruikers deze uit elkaar kunnen halen en weer kunnen samenstellen?' },
  { title: 'Schrijven + markeren in één', hzwk: 'Hoe zouden we schrijven en markeren kunnen combineren in één schrijfgerei zonder in te leveren op gebruiksgemak?' },
  { title: 'Friemelen zonder verstoring', hzwk: 'Hoe zouden we een pen zo kunnen ontwerpen dat gebruikers eraan kunnen friemelen, zonder dat dit de werking of andere functies verstoort?' },
  { title: 'Beveiligde pen tegen fraude', hzwk: 'Hoe zouden we een pen kunnen uitrusten met identiteitsverificatie (zoals vingerafdrukherkenning), zodat handtekeningen en geschreven documenten beveiligd zijn tegen fraude?' },
];

const gripes = [
  { title: 'Schrijfvermoeidheid', hzwk: 'Hoe zouden we langdurig of veel schrijven minder vermoeiend kunnen maken voor de gebruiker?' },
  { title: 'Moeilijk corrigeren', hzwk: 'Hoe zouden we het corrigeren van geschreven tekst met schrijfgerei gemakkelijker kunnen maken?' },
  { title: 'Schrijfgerei raakt op', hzwk: 'Hoe zouden we kunnen voorkomen dat schrijfgerei onverwacht opraakt of leeg is?' },
  { title: 'Onleesbaar handschrift', hzwk: 'Hoe zouden we ervoor kunnen zorgen dat handschrift beter leesbaar wordt?' },
  { title: 'Afhankelijk van andere producten', hzwk: 'Hoe zouden we schrijfgerei minder afhankelijk kunnen maken van andere producten of hulpmiddelen?' },
  { title: 'Nadeel linkshandigen', hzwk: 'Hoe zouden we schrijfgerei inclusiever kunnen ontwerpen, zodat het niet vooral voordelen biedt voor rechtshandigen ten koste van linkshandigen?' },
  { title: 'Storend geluid', hzwk: 'Hoe zouden we kunnen voorkomen dat een pen storende geluiden maakt tijdens gebruik?' },
  { title: 'Pen lekt bij leegraken', hzwk: 'Hoe zouden we kunnen voorkomen dat een pen lekt of frustratie veroorzaakt wanneer deze bijna leeg is?' },
];
---

<BaseLayout title="Immersive Research — Discover">
  <!-- Hero -->
  <section class="bg-bg-primary text-white overflow-hidden relative">
    <div class="absolute top-0 right-0 w-80 h-80 bg-phase-discover/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-20 w-64 h-64 bg-phase-refine/10 rounded-full blur-3xl"></div>

    <div class="max-w-5xl mx-auto px-6 py-16 md:py-24 relative z-10">
      <nav class="reveal text-sm mb-6 flex items-center gap-2">
        <a href={url('/')} class="text-white/40 hover:text-white/60 transition-colors">Home</a>
        <span class="text-white/20">/</span>
        <a href={url('/discover/')} class="text-white/40 hover:text-white/60 transition-colors">Discover</a>
        <span class="text-white/20">/</span>
        <span class="text-phase-discover font-medium">Immersive Research</span>
      </nav>
      <h1 class="reveal reveal-delay-1 font-[family-name:var(--font-display)] text-5xl md:text-7xl font-bold leading-[0.95] mb-4">
        Immersive<br /><span class="gradient-text">Research</span>
      </h1>
      <p class="reveal reveal-delay-2 text-xl text-white/60 max-w-3xl leading-relaxed">
        De wereld van de gebruiker begrijpen door onderdompeling. Niet oplossen, maar ontdekken.
      </p>
      <div class="reveal reveal-delay-3 w-24 h-1.5 rounded-full bg-phase-discover mt-8"></div>
    </div>
  </section>

  <!-- Inleiding -->
  <section class="bg-cream py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-8 text-center">Onderzoeksaanpak</h2>

      <div class="reveal reveal-delay-1 prose max-w-none mb-10">
        <p>Voor ons onderzoek binnen het vak innovatiemanagement hebben wij onderzoek gedaan naar schrijfgerei en de uitdagingen die hierbij komen kijken. Tijdens dit onderzoek hebben wij twee onderzoeksfasen toegepast: <strong>learn from experience</strong> en <strong>learn from users</strong>.</p>
      </div>

      <div class="reveal reveal-delay-2 grid md:grid-cols-2 gap-6">
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-discover rounded-xl flex items-center justify-center text-white text-lg">1</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Learn from Experience</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            Richt zich op het zelf ervaren van een probleem of situatie. Wij hebben gekeken naar onze eigen ervaringen met schrijfgerei. Door na te denken over deze ervaringen kwamen verschillende inzichten naar voren, opgedeeld in <strong class="text-phase-deliver">dreams</strong> (wensen/verbeteringen) en <strong class="text-phase-discover">gripes</strong> (frustraties/ergernissen).
          </p>
        </div>
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-define rounded-xl flex items-center justify-center text-white text-lg">2</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Learn from Users</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            Richt zich op het leren van de ervaringen van andere gebruikers. We hebben vragen opgesteld en aan verschillende mensen gesteld: wat vinden zij van het gebruik van een pen, wat zouden zij missen of willen toevoegen als alles mogelijk zou zijn?
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sessie 1: Learn from Experience -->
  <section class="bg-warm-gray py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">Sessie 1 — Learn from Experience</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-10">Brainstormen over eigen ervaringen met schrijfgerei</p>

      <div class="reveal reveal-delay-2 prose max-w-none mb-10">
        <p>We zijn gestart met een brainstormsessie over onze eigen ervaringen met schrijfgerei en ook het schrijfgebruik op de computer. We hebben onze ideeën en observaties opgeschreven en per punt aangegeven of het om een <strong class="text-phase-discover">gripe</strong> of een <strong class="text-phase-deliver">dream</strong> ging. Op deze manier kregen we een beter overzicht van zowel de huidige problemen als mogelijke verbeteringen.</p>
      </div>

      <!-- Timelapse video -->
      <div class="reveal reveal-delay-2 mb-8">
        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
          <video autoplay loop muted playsinline class="w-full">
            <source src={url('/images/research/sessie1-timelapse.mp4')} type="video/mp4" />
          </video>
        </div>
        <p class="text-dark/40 text-sm text-center mt-3 italic">Timelapse van sessie 1 — brainstormen over ervaringen met schrijfgerei</p>
      </div>
    </div>
  </section>

  <!-- Foto's sessie 1 -->
  <section class="bg-cream py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">Foto's</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-10">Beelden uit het veldonderzoek</p>

      <div class="reveal reveal-delay-2 max-w-2xl mx-auto">
        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
          <img src={url('/images/research/sessie1-foto.jpeg')} alt="Sessie 1 — brainstorm resultaten" class="w-full" />
        </div>
        <p class="text-dark/40 text-sm text-center mt-3 italic">Resultaten brainstormsessie 1</p>
      </div>
    </div>
  </section>

  <!-- Sessie 2: Learn from Users -->
  <section class="bg-warm-gray py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">Sessie 2 — Learn from Users</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-10">Interviews en gesprekken met gebruikers</p>

      <div class="reveal reveal-delay-2 prose max-w-none mb-10">
        <p>In de tweede sessie hebben we een andere methode toegepast: we hebben innovatie-ideeën op papier gezet en deze vervolgens geclusterd in thema's (zoals beveiliging). Daarnaast hebben we andere mensen gevraagd naar hun ervaringen met schrijfgerei.</p>
      </div>

      <div class="reveal reveal-delay-2 grid md:grid-cols-2 gap-6">
        <!-- Interview Anna -->
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-define rounded-xl flex items-center justify-center text-white text-sm font-bold">A</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-lg">Interview Anna</h3>
          </div>
          <ul class="text-text-secondary text-sm space-y-2 list-none pl-0">
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Friemelen aan pen is fijn</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Zwaardere pen zou chill zijn</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Veel kleuropties, niet te dikke pen</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Kunnen friemelen zonder dat het de rest beïnvloedt</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">−</span> Geluid: te luid klikgeluid</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">−</span> Vieze handen door inkt</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">−</span> Kapot clipje is frustrerend</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">−</span> Pen die leeg raakt</li>
          </ul>
        </div>

        <!-- Interview Famke -->
        <div class="bg-bg-elevated rounded-2xl p-6 border border-white/5 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-phase-design rounded-xl flex items-center justify-center text-white text-sm font-bold">F</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-lg">Interview Famke</h3>
          </div>
          <ul class="text-text-secondary text-sm space-y-2 list-none pl-0">
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Ergonomisch gevormde grip is chill</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Pen demonteren en in elkaar zetten</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Schrijven en markeren in één pen</li>
            <li class="flex items-start gap-2"><span class="text-phase-deliver mt-0.5">+</span> Balpen schrijft het fijnst</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">−</span> Dikke pen is hinderlijk</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">−</span> Geen textuur / te glad is vervelend</li>
            <li class="flex items-start gap-2"><span class="text-phase-discover mt-0.5">−</span> Niet te veel kleine onderdelen</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Dreams & Gripes -->
  <section class="bg-cream py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="reveal font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold text-dark mb-3 text-center">Discover Challenges</h2>
      <p class="reveal reveal-delay-1 text-dark/50 text-center mb-4">Dreams & Gripes omgezet naar HZWK-challenges</p>
      <p class="reveal reveal-delay-1 text-dark/40 text-center text-sm mb-10 max-w-2xl mx-auto">
        Door de twee onderzoeksfasen te combineren hebben we zowel onze eigen ervaringen als die van andere gebruikers geanalyseerd.
        Dit heeft ons geholpen om een beter beeld te krijgen van de uitdagingen rondom schrijfgerei en mogelijke kansen voor innovatie.
      </p>

      <div class="reveal reveal-delay-2 grid md:grid-cols-2 gap-8">
        <!-- Dreams -->
        <div>
          <div class="flex items-center gap-2 mb-5">
            <div class="w-8 h-8 bg-phase-deliver rounded-lg flex items-center justify-center text-white text-sm">&#10024;</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Dreams</h3>
            <span class="text-dark/30 text-sm ml-auto">{dreams.length} challenges</span>
          </div>
          <div class="space-y-3">
            {dreams.map((d, i) => (
              <div class="bg-phase-deliver/5 border border-phase-deliver/20 rounded-xl p-4">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-phase-deliver font-bold text-sm">{i + 1}.</span>
                  <span class="text-text-primary font-semibold text-sm">{d.title}</span>
                </div>
                <p class="text-text-secondary text-sm leading-relaxed italic">{d.hzwk}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Gripes -->
        <div>
          <div class="flex items-center gap-2 mb-5">
            <div class="w-8 h-8 bg-phase-discover rounded-lg flex items-center justify-center text-white text-sm">&#9889;</div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-dark text-xl">Gripes</h3>
            <span class="text-dark/30 text-sm ml-auto">{gripes.length} challenges</span>
          </div>
          <div class="space-y-3">
            {gripes.map((g, i) => (
              <div class="bg-phase-discover/5 border border-phase-discover/20 rounded-xl p-4">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-phase-discover font-bold text-sm">{i + 1}.</span>
                  <span class="text-text-primary font-semibold text-sm">{g.title}</span>
                </div>
                <p class="text-text-secondary text-sm leading-relaxed italic">{g.hzwk}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="bg-bg-primary text-white py-16">
    <div class="max-w-4xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <a href={url('/discover/scenario/')} class="reveal inline-flex items-center gap-2 text-white/50 hover:text-white font-bold transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
        Scenariobouwing
      </a>
      <a href={url('/discover/challenges/')} class="reveal reveal-delay-1 inline-flex items-center gap-2 bg-phase-discover text-white font-bold px-6 py-3 rounded-full hover:scale-105 transition-transform">
        Challenges
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </a>
    </div>
  </section>
</BaseLayout>
